# Copia este archivo a .env y rellena los valores reales.
# NUNCA versionar el .env real (está en .gitignore).
# Solo variables EXPO_PUBLIC_* llegan al cliente — el resto del modelo
# de seguridad (service role keys, secrets) vive en Supabase Edge Functions.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY
