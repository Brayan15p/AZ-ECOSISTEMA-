# ============================================================
# AZ Ecosistema — variables de entorno (plantilla)
# Copia a .env y rellena. NUNCA subas .env al repo.
# ============================================================

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # solo backend / Edge Functions, nunca cliente

# Expo (deben llevar prefijo EXPO_PUBLIC_ para exponerse al cliente)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Next.js (NEXT_PUBLIC_ para el cliente)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Bold (pasarela de pagos Colombia) ---
# https://developers.bold.co
BOLD_API_KEY=
BOLD_SECRET_KEY=                  # para firmar/verificar webhooks
NEXT_PUBLIC_BOLD_PUBLIC_KEY=
BOLD_WEBHOOK_SECRET=
